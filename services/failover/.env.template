# services/failover/.env.template — per-service secrets, layered on top of the
# repo-root .env.template by services/launchd/op-wrap.sh (its LOCAL_ENV rule:
# a .env.template in the service's WorkingDirectory is added to `op run`).
# Scoped here, not repo root, so a missing vault item can only break the
# freshness check, never the other launchd services.

# iMessage handle that receives failover freshness alerts (freshness_check.py).
ALERT_IMESSAGE_TO="op://web-variables/ALERT_IMESSAGE/handle"
